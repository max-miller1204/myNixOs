{
  "name": "lsp-servers",
  "description": "Global language server configurations",
  "version": "1.0.0",
  "lspServers": {
    "nix": {
      "command": "nixd",
      "args": [],
      "extensionToLanguage": {
        ".nix": "nix"
      }
    },
    "typescript": {
      "command": "typescript-language-server",
      "args": ["--stdio"],
      "extensionToLanguage": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact"
      }
    },
    "rust": {
      "command": "rust-analyzer",
      "args": [],
      "extensionToLanguage": {
        ".rs": "rust"
      }
    },
    "python": {
      "command": "pyright-langserver",
      "args": ["--stdio"],
      "extensionToLanguage": {
        ".py": "python"
      }
    },
    "lua": {
      "command": "lua-language-server",
      "args": [],
      "extensionToLanguage": {
        ".lua": "lua"
      }
    },
    "json": {
      "command": "vscode-json-language-server",
      "args": ["--stdio"],
      "extensionToLanguage": {
        ".json": "json",
        ".jsonc": "jsonc"
      }
    },
    "html": {
      "command": "vscode-html-language-server",
      "args": ["--stdio"],
      "extensionToLanguage": {
        ".html": "html"
      }
    },
    "css": {
      "command": "vscode-css-language-server",
      "args": ["--stdio"],
      "extensionToLanguage": {
        ".css": "css",
        ".scss": "scss",
        ".less": "less"
      }
    },
    "c": {
      "command": "clangd",
      "args": [],
      "extensionToLanguage": {
        ".c": "c",
        ".h": "c",
        ".cpp": "cpp",
        ".hpp": "cpp",
        ".cc": "cpp",
        ".cxx": "cpp"
      }
    },
    "haskell": {
      "command": "haskell-language-server-wrapper",
      "args": ["--lsp"],
      "extensionToLanguage": {
        ".hs": "haskell"
      }
    },
    "swift": {
      "command": "sourcekit-lsp",
      "args": [],
      "extensionToLanguage": {
        ".swift": "swift"
      }
    },
    "markdown": {
      "command": "marksman",
      "args": ["server"],
      "extensionToLanguage": {
        ".md": "markdown"
      }
    }
  }
}
